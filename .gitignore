/target/
**/*.rs.bk
/.cache/
# Staged-pipeline content-addressed cache (parsimony pipeline run).
/.parsimony/
# Generated VdW-surface meshes — regenerated by `parsimony translate-mycoplasma`
# and `parsimony mesh` from cellpack data + RCSB. Large; never commit.
/examples/pdb_meshes/
# PDB / mmCIF structures fetched from RCSB on demand (incl. ligand components).
/examples/pdb_cache/
# Generated viewer packs — regenerated by `parsimony pipeline run` / `demos`.
/viewer/data/*.pack.json
